---
import { ClientRouter } from 'astro:transitions';
import { getTranslation, locales, localeNames, localeLabels, type Locale } from '../i18n';
const { title, description, lang = 'en', image } = Astro.props as { title: string; description?: string; lang?: Locale; image?: string };
const base = import.meta.env.BASE_URL;
const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = site + Astro.url.pathname;
const ogImage = image
  ? (image.startsWith('http') ? image : `${site}${base}${image.replace(/^\//, '')}`)
  : `${site}${base}og-image.png`;
const t = getTranslation(lang);

// Locale home URLs for the language switcher.
const localeHref = (l: Locale) => (l === 'en' ? base : `${base}${l}/`);

// hreflang alternates only make sense on the localized home pages.
const normalizedPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isLocaleHome = normalizedPath === base.replace(/\/$/, '') || normalizedPath === `${base}el`.replace(/\/$/, '') || normalizedPath === `${base}de`.replace(/\/$/, '');
const ogLocale: Record<Locale, string> = { en: 'en_US', el: 'el_GR', de: 'de_DE' };
const alternateLocales = locales.filter((l) => l !== lang);

// Paste the content value from Google Search Console's "HTML tag" method here
// (e.g. 'AbC123...'), then redeploy and click Verify in Search Console.
const googleSiteVerification = '';

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Christina Pardali',
  jobTitle: 'Partner Solution Architect',
  worksFor: { '@type': 'Organization', name: 'Microsoft' },
  url: site || 'https://christinapa.github.io',
  image: ogImage,
  address: { '@type': 'PostalAddress', addressLocality: 'Munich', addressCountry: 'DE' },
  sameAs: [
    'https://www.linkedin.com/in/christine-pardali/',
    'https://github.com/ChristinaPa',
  ],
};

const nav = [
  { href: `${base}#about`, label: t.nav.about },
  { href: `${base}#focus`, label: t.nav.focus },
  { href: `${base}#experience`, label: t.nav.experience },
  { href: `${base}#education`, label: t.nav.education },
  { href: `${base}#skills`, label: t.nav.skills },
  { href: `${base}#community`, label: t.nav.community },
  { href: `${base}blog`, label: t.nav.blog },
  { href: `${base}#resources`, label: t.nav.resources },
  { href: `${base}#interests`, label: t.nav.interests },
  { href: `${base}#contact`, label: t.nav.contact },
];
---

<!doctype html>
<html lang={t.htmlLang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      // Mark JS as available before paint so scroll-reveal hides elements without a flash.
      document.documentElement.classList.add('js');
    </script>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg?v=3`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <link rel="alternate" type="application/rss+xml" title="Christina Pardali — Writing" href={`${base}rss.xml`} />
    <meta name="theme-color" content="#2e7d52" />
    <link rel="canonical" href={canonical} />
    {isLocaleHome && locales.map((l) => (
      <link rel="alternate" hreflang={l} href={site + localeHref(l)} />
    ))}
    {isLocaleHome && <link rel="alternate" hreflang="x-default" href={site + base} />}
    {googleSiteVerification && (
      <meta name="google-site-verification" content={googleSiteVerification} />
    )}
    <title>{title}</title>
    <meta name="description" content={description ?? 'Personal site of Christina Pardali, Partner Solution Architect at Microsoft EMEA.'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description ?? ''} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale[lang]} />
    {alternateLocales.map((l) => (
      <meta property="og:locale:alternate" content={ogLocale[l]} />
    ))}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description ?? ''} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <nav class="nav container" aria-label="Primary">
        <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
        <ul id="nav-menu" class="nav-menu">
          {nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
          <li class="lang-switch" aria-label="Language">
            {locales.map((l) => (
              <a
                href={localeHref(l)}
                class={l === lang ? 'lang-link active' : 'lang-link'}
                aria-current={l === lang ? 'true' : undefined}
                aria-label={localeLabels[l]}
                title={localeLabels[l]}
              >{localeNames[l]}</a>
            ))}
          </li>
          <li>
            <button class="theme-toggle" aria-label="Toggle dark mode" title="Toggle theme">🌙</button>
          </li>
        </ul>
      </nav>
    </header>

    {t.i18nNotice && (
      <div class="translation-notice" role="note">
        <div class="container">
          <span aria-hidden="true">🌐</span>
          <span>{t.i18nNotice.text}</span>
          <a href={base}>{t.i18nNotice.linkLabel} →</a>
        </div>
      </div>
    )}

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>© {new Date().getFullYear()} Christina Pardali. Built with <a href="https://astro.build" rel="noopener">Astro</a>.</p>
      </div>
    </footer>

    <button class="back-to-top" aria-label="Back to top" title="Back to top" hidden>↑</button>

    <script is:inline>
      // Scroll-reveal: fade/slide elements in as they enter the viewport.
      // Re-runs on every navigation (astro:page-load) so View Transitions keep working.
      (function () {
        function init() {
          const selector = '.card, .timeline-item, .cert-group, .skill-group, .toolbox, .what-i-do-list li, .post-item';
          const els = Array.from(document.querySelectorAll(selector));
          if (!els.length) return;
          const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (reduce || !('IntersectionObserver' in window)) {
            els.forEach((el) => el.classList.add('is-visible'));
            return;
          }
          const observer = new IntersectionObserver(
            (entries, obs) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                const el = entry.target;
                const siblings = Array.from(el.parentElement ? el.parentElement.children : [el]);
                const idx = Math.max(0, siblings.indexOf(el));
                el.style.transitionDelay = Math.min(idx, 6) * 80 + 'ms';
                el.classList.add('is-visible');
                obs.unobserve(el);
              });
            },
            { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
          );
          els.forEach((el) => observer.observe(el));
        }
        document.addEventListener('astro:page-load', init);
      })();
    </script>

    <script is:inline>
      // Theme toggle with persistence + system preference fallback
      (function () {
        const root = document.documentElement;
        const apply = () => {
          // Dark mode is the default; respect an explicit saved preference.
          root.dataset.theme = localStorage.getItem('theme') ?? 'dark';
        };
        apply();
        // Re-apply after a View Transition swap so the theme doesn't flash back to default.
        document.addEventListener('astro:after-swap', apply);

        document.addEventListener('click', (e) => {
          const target = e.target;
          if (target instanceof Element && target.closest('.theme-toggle')) {
            const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
            root.dataset.theme = next;
            localStorage.setItem('theme', next);
          }
          if (target instanceof Element && target.closest('.nav-toggle')) {
            const btn = target.closest('.nav-toggle');
            const menu = document.getElementById('nav-menu');
            const open = menu.classList.toggle('open');
            btn.setAttribute('aria-expanded', String(open));
          }
          if (target instanceof Element && target.closest('.nav-menu a')) {
            document.getElementById('nav-menu')?.classList.remove('open');
          }
        });
      })();
    </script>

    <script is:inline>
      // Back-to-top button: show after scrolling, smooth-scroll to top.
      // Listeners live on window/document (persist across navigation); button is re-queried each time.
      (function () {
        const onScroll = () => {
          const btn = document.querySelector('.back-to-top');
          if (!btn) return;
          if (window.scrollY > 600) btn.removeAttribute('hidden');
          else btn.setAttribute('hidden', '');
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        document.addEventListener('click', (e) => {
          if (e.target instanceof Element && e.target.closest('.back-to-top')) {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }
        });
        document.addEventListener('astro:page-load', onScroll);
      })();
    </script>

    <script is:inline>
      // Scrollspy: highlight the nav link of the section currently in view.
      // Re-runs on every navigation (astro:page-load) so it works after View Transitions.
      (function () {
        function init() {
          const links = Array.from(document.querySelectorAll('.nav-menu a[href*="#"]'));
          if (!links.length) return;
          const map = new Map();
          for (const link of links) {
            const hash = link.getAttribute('href')?.split('#')[1];
            if (!hash) continue;
            const section = document.getElementById(hash);
            if (section) map.set(section, link);
          }
          if (!map.size) return;
          const observer = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                const link = map.get(entry.target);
                if (!link) continue;
                if (entry.isIntersecting) {
                  links.forEach((l) => l.classList.remove('active'));
                  link.classList.add('active');
                }
              }
            },
            { rootMargin: '-45% 0px -50% 0px', threshold: 0 }
          );
          map.forEach((_, section) => observer.observe(section));
        }
        document.addEventListener('astro:page-load', init);
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
