---
import BaseLayout from '../layouts/BaseLayout.astro';
import { articles } from '../data/articles';

const base = import.meta.env.BASE_URL;

// --- Edit your content here -------------------------------------------------
const profile = {
  name: 'Christina Pardali',
  role: 'Partner Solution Architect',
  tagline:
    'Partner Solution Architect at Microsoft EMEA, based in Munich. I work with Microsoft\u2019s partner ecosystem\u2014companies that build, integrate, and deliver solutions on top of Microsoft technologies\u2014to help them design and deploy reliable, secure, and cost-efficient AI applications in the cloud, and drive GitHub adoption across the ecosystem.',
  email: 'xristinapar8@gmail.com',
  phone: '+491751293078',
  linkedin: 'https://www.linkedin.com/in/christine-pardali/',
  github: 'https://github.com/ChristinaPa',
  // Replace with your public Credly profile URL when you have it.
  credly: 'https://www.credly.com/',
  location: 'Munich, Germany',
};

const projects = [
  {
    title: 'Partner AI Applications & GitHub Adoption',
    description:
      'Work with EMEA partners to design reliable, performant, secure, and cost-efficient AI applications in the cloud, guide their cloud services offerings, and drive GitHub adoption.',
    tags: ['AI Applications', 'GitHub', 'Cloud'],
    link: profile.linkedin,
  },
  {
    title: 'Microsoft Fabric Executive Briefings',
    description:
      'Delivered Microsoft Fabric and Data Analytics sessions at the Microsoft Executive Center EMEA in Munich, engaging 50+ senior decision makers across industries.',
    tags: ['Microsoft Fabric', 'Data Analytics', 'Executive'],
    link: profile.linkedin,
  },
  {
    title: 'Azure Health Bot Learning Path (Publication)',
    description:
      'Co-authored the Microsoft Learn path "Create intelligent health bots with Azure Health Bot," teaching developers to build healthcare bots.',
    tags: ['Azure Health Bot', 'Microsoft Learn', 'AI'],
    link: 'https://docs.microsoft.com/learn/paths/create-bots-azure-health-bot/',
  },
];

const experience = [
  {
    role: 'Partner Solution Architect — EMEA',
    org: 'Microsoft',
    period: 'Feb 2026 – Present · Munich',
    summary:
      'Work with EMEA partners on AI applications and GitHub adoption, providing technical guidance on building reliable, performant, secure, and cost-efficient cloud solutions and shaping their cloud services offerings. Communications Lead of the Mosaic Inclusion Network in Germany, championing multicultural inclusion and representation.',
  },
  {
    role: 'Data Analytics Cloud Solution Architect — EMEA',
    org: 'Microsoft',
    period: 'Sep 2022 – Feb 2026 · Munich',
    summary:
      'Specialized in Microsoft Fabric, Azure Data Factory, Azure Synapse Analytics, Azure Databricks, and Power BI. Ran proof of concepts and architecture reviews for enterprise customers, delivered technical workshops, drove feature requests with Product Engineering, and coordinated AI and lakehouse migration projects end to end. Delivered Microsoft Fabric sessions at the Microsoft Executive Center EMEA to 50+ senior decision makers.',
  },
  {
    role: 'Sales Executive Intern — Business Applications',
    org: 'Microsoft',
    period: 'Oct 2021 – Mar 2022 · Munich',
    summary:
      'Ran market research and a Dynamics 365 Remote Assist lead-generation campaign for Automotive and Manufacturing accounts using LinkedIn Sales Navigator and Dynamics 365 Sales, built outreach templates, analyzed campaign results, and supported presales demos.',
  },
  {
    role: 'Microsoft Learn Student Ambassador',
    org: 'Microsoft',
    period: 'Jan 2020 – Mar 2022',
    summary:
      'Authored a Microsoft Learn path on Azure Health Bot and spoke at virtual events on Azure Machine Learning, Power Platform, Cloud Security, and Health Bot — including the Global AI Student Conference 2021 — while building local tech communities.',
  },
  {
    role: 'Junior Radio Frequency Engineer',
    org: 'Further Enterprise Solutions (FES)',
    period: 'Jun 2021 – Sep 2021 · Thessaloniki',
    summary:
      'Supported radio frequency engineering, including E911 call testing for small cells and creating KPI reports for network efficiency.',
  },
  {
    role: 'Network Infrastructure Intern',
    org: 'Aristotle University IT Center',
    period: 'Jan 2020 – Jun 2020 · Thessaloniki',
    summary:
      'Gained hands-on experience in network management, traffic accounting, wireless networks, routing, and switching using LibreNMS, Icinga, SecureCRT, and Cisco Prime Infrastructure.',
  },
];

const education = [
  {
    degree: 'M.Eng. Electrical & Computer Engineering — Telecommunications',
    org: 'Aristotle University of Thessaloniki (AUTH)',
    period: '2016 – 2022',
    summary: 'Telecommunications Engineering. Thesis: Interference in novel leadless pacemaker implants.',
  },
];

const certifications = [
  'Microsoft Fabric Analytics Engineer Associate',
  'Microsoft Certified: Azure Data Engineer Associate',
  'Microsoft Certified: Azure AI Engineer Associate',
  'Microsoft Certified: Dynamics 365 Fundamentals (CRM)',
  'Microsoft Certified: Azure Data Fundamentals',
  'Microsoft Certified: Azure Fundamentals',
  'Microsoft Certified: Azure AI Fundamentals',
  'Databricks Lakehouse Fundamentals',
  'Databricks Generative AI Fundamentals',
  'Data Science Course',
  'Youthpass — Erasmus+ Youth Exchange "Meaning for Wellbeing"',
];

const skillGroups = [
  {
    name: 'Data & Analytics',
    items: ['Microsoft Fabric', 'Azure Synapse Analytics', 'Azure Data Factory', 'Azure Databricks', 'Power BI', 'Spark'],
  },
  {
    name: 'Programming',
    items: ['Python', 'SQL'],
  },
  {
    name: 'AI',
    items: ['Azure AI', 'Generative AI', 'Azure Machine Learning', 'Azure Health Bot'],
  },
  {
    name: 'Cloud & Architecture',
    items: ['Azure', 'Solution Architecture', 'Lakehouse', 'Proof of Concepts', 'Architecture Reviews'],
  },
];

const interests = [
  {
    icon: '🥾',
    title: 'Hiking adventures',
    description:
      'Most weekends you\'ll find me on a trail. I love long hikes in the Bavarian Alps near Munich — chasing summit views, alpine lakes, and the quiet that comes with a few hours on the mountain.',
  },
  {
    icon: '🏔️',
    title: 'Mountains & the outdoors',
    description:
      'From the Greek mountains I grew up near to the Alps I explore now, being outdoors keeps me grounded. There\'s no better way to reset and think clearly than a long climb.',
  },
  {
    icon: '📸',
    title: 'Travel & exploring',
    description:
      'I enjoy discovering new places, cultures, and routes — and capturing the views along the way. New trails and new cities both bring the same sense of curiosity.',
  },
];

const community = [
  {
    icon: '🌍',
    title: 'Mosaic Inclusion Network',
    description:
      'Communications Lead of the Mosaic Inclusion Network in Germany, championing multicultural inclusion and representation across our community at Microsoft.',
  },
  {
    icon: '💻',
    title: 'ReDI School volunteering',
    description:
      'Volunteering with ReDI School of Digital Integration, helping newcomers and underrepresented groups build digital and tech skills to open doors into the industry.',
  },
  {
    icon: '🎓',
    title: 'Student leadership & volunteering',
    description:
      'From AIESEC and the ECESCON student engineering conference to my time as a Microsoft Learn Student Ambassador, I have always invested in mentoring others and growing diverse tech communities.',
  },
];
// ---------------------------------------------------------------------------
---

<BaseLayout title={`${profile.name} — ${profile.role}`} description={profile.tagline}>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="avatar-wrap">
        <img
          class="avatar"
          src={`${base}profile.jpg`}
          alt={profile.name}
          width="150"
          height="150"
          loading="eager"
          onerror="this.style.display='none'"
        />
        <span class="avatar-initials" aria-hidden="true">CP</span>
      </div>
      <p class="eyebrow">{profile.role}</p>
      <h1>Hi, I'm <span class="gradient">{profile.name}</span></h1>
      <p class="tagline">{profile.tagline}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="#contact">Get in touch</a>
        <a class="btn btn-ghost" href="#projects">View work</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about">
    <div class="container">
      <p class="eyebrow">About</p>
      <h2 class="section-title">A bit about me</h2>
      <div class="about-grid">
        <div>
          <p>
            I'm a Partner Solution Architect on Microsoft's EMEA team, based in Munich. I work with
            partners to build reliable, performant, secure, and cost-efficient AI applications in the
            cloud, help them shape their cloud services offerings, and drive GitHub adoption across the
            ecosystem.
          </p>
          <p>
            Before this, I spent three and a half years as a Data Analytics Cloud Solution Architect,
            specializing in Microsoft Fabric, Azure Databricks, Synapse, Data Factory, and Power BI. I
            love delivering technical workshops, briefing executives, and sharing what I learn. Outside
            work, I'm Communications Lead of the Mosaic Inclusion Network in Germany.
          </p>
        </div>
        <div class="about-facts">
          <div class="fact"><span>Role</span><span>{profile.role}</span></div>
          <div class="fact"><span>Location</span><span>{profile.location}</span></div>
          <div class="fact"><span>Focus</span><span>AI Apps · Cloud · GitHub</span></div>
          <div class="fact"><span>Languages</span><span>EL · EN · DE</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects">
    <div class="container">
      <p class="eyebrow">Portfolio</p>
      <h2 class="section-title">Selected projects</h2>
      <p class="section-lead">A few things I've designed, built, or contributed to.</p>
      <div class="grid grid-3">
        {projects.map((p) => (
          <article class="card">
            <h3>{p.title}</h3>
            <p>{p.description}</p>
            <div class="tag-row">
              {p.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            {p.link && (
              <p style="margin-top:1rem;margin-bottom:0">
                <a href={p.link} rel="noopener">View →</a>
              </p>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience">
    <div class="container">
      <p class="eyebrow">Career</p>
      <h2 class="section-title">Experience</h2>
      <p class="section-lead">Where I've worked and what I focused on.</p>
      <div class="timeline">
        {experience.map((e) => (
          <div class="timeline-item">
            <h3>{e.role} · <span style="color:var(--accent)">{e.org}</span></h3>
            <p class="timeline-meta">{e.period}</p>
            <p>{e.summary}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Education -->
  <section id="education">
    <div class="container">
      <p class="eyebrow">Education</p>
      <h2 class="section-title">Education</h2>
      <div class="timeline">
        {education.map((e) => (
          <div class="timeline-item">
            <h3>{e.degree} · <span style="color:var(--accent)">{e.org}</span></h3>
            <p class="timeline-meta">{e.period}</p>
            <p>{e.summary}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section id="certifications">
    <div class="container">
      <p class="eyebrow">Credentials</p>
      <h2 class="section-title">Certifications</h2>
      <p class="section-lead">
        Microsoft and Databricks certifications.{' '}
        <a href={profile.credly} rel="noopener">View on Credly →</a>
      </p>
      <ul class="skill-list">
        {certifications.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills">
    <div class="container">
      <p class="eyebrow">Toolbox</p>
      <h2 class="section-title">Skills</h2>
      <p class="section-lead">Technologies and practices I work with regularly.</p>
      {skillGroups.map((g) => (
        <div class="skill-group">
          <h3>{g.name}</h3>
          <ul class="skill-list">
            {g.items.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Community & Inclusion -->
  <section id="community">
    <div class="container">
      <p class="eyebrow">What I care about</p>
      <h2 class="section-title">Community &amp; inclusion</h2>
      <p class="section-lead">
        Beyond architecture, I'm passionate about multicultural communities and inclusion — bringing
        people together and making sure everyone has a seat at the table.
      </p>
      <div class="grid grid-3">
        {community.map((c) => (
          <article class="card">
            <div class="interest-icon" aria-hidden="true">{c.icon}</div>
            <h3>{c.title}</h3>
            <p style="margin:0">{c.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Interests -->
  <section id="interests">
    <div class="container">
      <p class="eyebrow">Beyond work</p>
      <h2 class="section-title">Personal interests</h2>
      <p class="section-lead">
        When I'm not designing data and AI solutions, I'm usually outdoors — most often on a mountain trail.
      </p>
      <div class="grid grid-3">
        {interests.map((i) => (
          <article class="card">
            <div class="interest-icon" aria-hidden="true">{i.icon}</div>
            <h3>{i.title}</h3>
            <p style="margin:0">{i.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog preview -->
  {articles.length > 0 && (
    <section id="blog-preview">
      <div class="container">
        <p class="eyebrow">Writing</p>
        <h2 class="section-title">From the blog</h2>
        <p class="section-lead">Articles I've published on cloud, AI, and architecture.</p>
        <ul class="post-list">
          {articles.slice(0, 3).map((a) => (
            <li class="post-item card">
              <span class="post-source">{a.source}</span>
              <h3><a href={a.url} target="_blank" rel="noopener">{a.title}</a></h3>
              <p style="margin:0">{a.description}</p>
            </li>
          ))}
        </ul>
        <p style="margin-top:1.5rem">
          <a class="btn btn-ghost" href={`${base}blog`}>All articles →</a>
        </p>
      </div>
    </section>
  )}

  <!-- Contact -->
  <section id="contact" class="contact">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h2 class="section-title">Let's connect</h2>
      <p class="section-lead" style="margin-inline:auto">
        Interested in collaborating, or just want to say hi? I'd love to hear from you.
      </p>
      <div class="contact-links">
        <a class="btn btn-primary" href={`mailto:${profile.email}`}>Email me</a>
        <a class="btn btn-ghost" href={profile.linkedin} rel="noopener">LinkedIn</a>
        <a class="btn btn-ghost" href={profile.github} rel="noopener">GitHub</a>
      </div>
    </div>
  </section>
</BaseLayout>
