---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Page not found — Christina Pardali" description="The page you were looking for doesn't exist.">
  <section>
    <div class="container" style="text-align:center; padding-block:4rem">
      <p class="eyebrow">404</p>
      <h1 class="section-title">This page wandered off the trail</h1>
      <p class="section-lead" style="margin-inline:auto">
        The page you're looking for doesn't exist or may have moved. Let's get you back on track.
      </p>
      <div class="cta-row" style="justify-content:center">
        <a class="btn btn-primary" href={base}>Back home</a>
        <a class="btn btn-ghost" href={`${base}blog`}>Read the blog</a>
      </div>
    </div>
  </section>
</BaseLayout>
