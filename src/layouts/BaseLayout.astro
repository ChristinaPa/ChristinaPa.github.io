---
const { title, description } = Astro.props as { title: string; description?: string };
const base = import.meta.env.BASE_URL;
const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = site + Astro.url.pathname;
const ogImage = `${site}${base}og-image.png`;

// Paste the content value from Google Search Console's "HTML tag" method here
// (e.g. 'AbC123...'), then redeploy and click Verify in Search Console.
const googleSiteVerification = '';

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Christina Pardali',
  jobTitle: 'Partner Solution Architect',
  worksFor: { '@type': 'Organization', name: 'Microsoft' },
  url: site || 'https://christinapa.github.io',
  image: ogImage,
  address: { '@type': 'PostalAddress', addressLocality: 'Munich', addressCountry: 'DE' },
  sameAs: [
    'https://www.linkedin.com/in/christine-pardali/',
    'https://github.com/ChristinaPa',
  ],
};

const nav = [
  { href: `${base}#about`, label: 'About' },
  { href: `${base}#focus`, label: 'Focus areas' },
  { href: `${base}#experience`, label: 'Work experience' },
  { href: `${base}#education`, label: 'Education' },
  { href: `${base}#skills`, label: 'Skills' },
  { href: `${base}#community`, label: 'Community' },
  { href: `${base}blog`, label: 'Blog' },
  { href: `${base}#resources`, label: 'Resources' },
  { href: `${base}#interests`, label: 'Interests' },
  { href: `${base}#contact`, label: 'Contact' },
];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="canonical" href={canonical} />
    {googleSiteVerification && (
      <meta name="google-site-verification" content={googleSiteVerification} />
    )}
    <title>{title}</title>
    <meta name="description" content={description ?? 'Personal site of Christina Pardali, Partner Solution Architect at Microsoft EMEA.'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description ?? ''} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description ?? ''} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <nav class="nav container" aria-label="Primary">
        <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
        <ul id="nav-menu" class="nav-menu">
          {nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
          <li>
            <button class="theme-toggle" aria-label="Toggle dark mode" title="Toggle theme">🌙</button>
          </li>
        </ul>
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>© {new Date().getFullYear()} Christina Pardali. Built with <a href="https://astro.build" rel="noopener">Astro</a>.</p>
      </div>
    </footer>

    <script is:inline>
      // Theme toggle with persistence + system preference fallback
      (function () {
        const root = document.documentElement;
        const stored = localStorage.getItem('theme');
        // Dark mode is the default; respect an explicit saved preference.
        const theme = stored ?? 'dark';
        root.dataset.theme = theme;

        document.addEventListener('click', (e) => {
          const target = e.target;
          if (target instanceof Element && target.closest('.theme-toggle')) {
            const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
            root.dataset.theme = next;
            localStorage.setItem('theme', next);
          }
          if (target instanceof Element && target.closest('.nav-toggle')) {
            const btn = target.closest('.nav-toggle');
            const menu = document.getElementById('nav-menu');
            const open = menu.classList.toggle('open');
            btn.setAttribute('aria-expanded', String(open));
          }
          if (target instanceof Element && target.closest('.nav-menu a')) {
            document.getElementById('nav-menu')?.classList.remove('open');
          }
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
