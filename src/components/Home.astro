---
import { articles } from '../data/articles';
import { getTranslation, type Locale } from '../i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getTranslation(lang);
const base = import.meta.env.BASE_URL;

// --- Locale-invariant content -----------------------------------------------
// Proper nouns, product names, role titles, technology tags, certification
// names, and external links stay the same across locales. Translatable prose
// lives in src/i18n.ts and is merged by index where needed.
const profile = {
  name: 'Christina Pardali',
  role: 'Partner Solution Architect',
  email: 'xristinapar8@gmail.com',
  phone: '+491751293078',
  linkedin: 'https://www.linkedin.com/in/christine-pardali/',
  github: 'https://github.com/ChristinaPa',
  credly: 'https://www.credly.com/',
  location: 'Munich, Germany',
};

// Icons + tags are shared; titles/descriptions come from t.focus.topics.
const topicMeta = [
  { icon: '🤖', tags: ['Microsoft Foundry', 'Azure AI', 'GenAI'] },
  { icon: '🐙', tags: ['GitHub', 'Copilot', 'DevOps'] },
];

// Role + org are shared; period/summary come from t.experience.*
const experienceMicrosoftMeta = [
  { role: 'Partner Solution Architect — EMEA', org: 'Microsoft' },
  { role: 'Data Analytics Cloud Solution Architect — EMEA', org: 'Microsoft' },
  { role: 'Sales Executive Intern — Business Applications', org: 'Microsoft' },
  { role: 'Microsoft Learn Student Ambassador', org: 'Microsoft' },
];

const experienceEngineeringMeta = [
  { role: 'Junior Radio Frequency Engineer', org: 'Further Enterprise Solutions (FES)' },
  { role: 'Network Infrastructure Intern', org: 'Aristotle University IT Center' },
];

// Org + thesis link are shared; degree/period/summary/label come from t.education.
const educationMeta = [
  {
    org: 'Aristotle University of Thessaloniki (AUTH)',
    thesisLink: 'https://ikee.lib.auth.gr/record/338089/?ln=el',
  },
];

const certificationsAssociate = [
  'Microsoft Fabric Analytics Engineer Associate',
  'Microsoft Certified: Azure Data Engineer Associate',
  'Microsoft Certified: Azure AI Engineer Associate',
];

const certificationsFundamentals = [
  'Microsoft Certified: Azure Fundamentals',
  'Microsoft Certified: Azure AI Fundamentals',
  'Microsoft Certified: Azure Data Fundamentals',
  'Microsoft Certified: Dynamics 365 Fundamentals (CRM)',
  'Databricks Lakehouse Fundamentals',
  'Databricks Generative AI Fundamentals',
  'GitHub Foundations',
  'GitHub Copilot',
  'GitHub Actions',
];

// Skill items are shared (product names); group names come from t.skills.groupNames.
const skillGroupItems = [
  ['Microsoft Fabric', 'Azure Synapse Analytics', 'Azure Data Factory', 'Power BI', 'Spark'],
  ['Microsoft Foundry', 'Azure Machine Learning'],
  ['GitHub', 'GitHub Copilot'],
];

// Toolbox icons — brand names stay in English across locales. SVGs live in public/icons/.
const toolbox = [
  { name: 'VS Code', icon: 'vscode' },
  { name: 'GitHub', icon: 'github' },
  { name: 'GitHub Copilot', icon: 'copilot' },
  { name: 'Azure', icon: 'azure' },
  { name: 'Azure Databricks', icon: 'databricks' },
  { name: 'Python', icon: 'python' },
  { name: 'SQL', icon: 'sql' },
];

// Hero “by the numbers” strip. Values are derived from real content; labels are translated.
const heroStats: { value?: number; display?: string; icon: string }[] = [
  { value: 3, icon: '🗣️' },
  { value: 2, icon: '🌍' },
  { value: 4.5, icon: '📅' },
  { display: '∞', icon: '🏔️' },
];

// Icons are shared; titles/descriptions/bullets/notes come from t.interests.items.
const interestIcons = ['🥾', '✈️', '🏃‍♀️', '🌱', '🧭'];

// Icons + external link URLs are shared; text comes from t.community.items.
const communityMeta: { icon: string; links?: string[] }[] = [
  { icon: '🌍' },
  {
    icon: '💻',
    links: [
      'https://www.linkedin.com/posts/redi-school-of-digital-integration_preparing-our-volunteer-teachers-for-spring-activity-7442232610602381312-7NYA',
    ],
  },
  { icon: '🎓' },
];

// Icons + link URLs/labels are shared (technical English); group names/notes/intro come from t.resources.
const resourceGroupsMeta: { icon: string; links: { label: string; url: string }[] }[] = [
  {
    icon: '🤖',
    links: [
      { label: 'microsoft/agentic-factory-hack — predictive maintenance with Microsoft Foundry, multi-agent workflows & MCP', url: 'https://github.com/microsoft/agentic-factory-hack' },
      { label: 'Microsoft — AI Solution Accelerators', url: 'https://accelerators.ms/' },
      { label: 'Azure AI Landing Zones', url: 'https://azure.github.io/AI-Landing-Zones/' },
    ],
  },
  {
    icon: '🐙',
    links: [
      { label: 'Awesome GitHub Copilot', url: 'https://awesome-copilot.github.com/' },
      { label: 'agentskills/agentskills — spec & docs for Agent Skills', url: 'https://github.com/agentskills/agentskills' },
      { label: 'bradygaster/squad — AI agent teams for any project', url: 'https://github.com/bradygaster/squad' },
    ],
  },
];
---

<!-- Hero -->
<section class="hero">
  <div class="container hero-inner">
    <div class="avatar-wrap">
      <img
        class="avatar"
        src={`${base}profile.jpg`}
        alt={profile.name}
        width="150"
        height="150"
        loading="eager"
        onerror="this.style.display='none'"
      />
      <span class="avatar-initials" aria-hidden="true">CP</span>
    </div>
    <p class="eyebrow">{t.hero.role}</p>
    <h1>{t.hero.greeting} <span class="gradient">{profile.name}</span></h1>
    <p class="tagline">{t.hero.welcome}</p>
    <div class="cta-row">
      <a class="btn btn-primary" href="#contact">{t.hero.ctaPrimary}</a>
      <a class="btn btn-ghost" href="#focus">{t.hero.ctaSecondary}</a>
    </div>
    <dl class="hero-stats">
      {heroStats.map((s, i) => (
        <div class="hero-stat" aria-label={`${s.display ?? s.value} ${t.hero.stats[i]}`}>
          <dt class="hero-stat-num" data-count={s.value ?? ''}>{s.display ?? s.value}</dt>
          <dd class="hero-stat-label"><span aria-hidden="true">{s.icon}</span> {t.hero.stats[i]}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<!-- About -->
<section id="about">
  <div class="container">
    <p class="eyebrow">{t.about.eyebrow}</p>
    <h2 class="section-title">{t.about.title}</h2>
    <div class="about-grid">
      <div>
        <p set:html={t.about.para1Html}></p>
        <p set:html={t.about.para2Html}></p>
        <p set:html={t.about.para3Html}></p>
      </div>
      <div class="about-facts">
        <div class="fact"><span>💼 {t.about.factRole}</span><span>{profile.role}</span></div>
        <div class="fact"><span>📍 {t.about.factLocation}</span><span>{t.about.locationValue}</span></div>
        <div class="fact"><span>🎯 {t.about.factFocus}</span><span>{t.about.focusValue}</span></div>
        <div class="fact"><span>🗣️ {t.about.factLanguages}</span><span>{t.about.languagesValue}</span></div>
      </div>
    </div>
    <p id="emea-note" class="footnote" set:html={t.about.footnoteHtml}></p>
  </div>
</section>

<!-- Focus areas with partners -->
<section id="focus">
  <div class="container">
    <p class="eyebrow">{t.focus.eyebrow}</p>
    <h2 class="section-title">{t.focus.title}</h2>
    <p class="section-lead">{t.focus.lead}</p>
    <div class="grid grid-3">
      {topicMeta.map((tp, i) => (
        <article class="card">
          <div class="interest-icon" aria-hidden="true">{tp.icon}</div>
          <h3>{t.focus.topics[i].title}</h3>
          <p>{t.focus.topics[i].description}</p>
          <div class="tag-row">
            {tp.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </article>
      ))}
    </div>

    <div class="what-i-do">
      <h3 class="experience-group-title">{t.focus.weekTitle}</h3>
      <p class="section-lead">{t.focus.weekLead}</p>
      <ul class="what-i-do-list">
        {t.focus.whatIDo.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </div>
</section>

<!-- Experience -->
<section id="experience">
  <div class="container">
    <p class="eyebrow">{t.experience.eyebrow}</p>
    <h2 class="section-title">{t.experience.title}</h2>
    <p class="section-lead">{t.experience.lead}</p>

    <h3 class="experience-group-title">{t.experience.microsoftTitle}</h3>
    <div class="timeline">
      {experienceMicrosoftMeta.map((e, i) => (
        <div class="timeline-item">
          <h3>{e.role}</h3>
          <p class="timeline-meta">{t.experience.microsoft[i].period}</p>
          <p>{t.experience.microsoft[i].summary}</p>
        </div>
      ))}
    </div>

    <h3 class="experience-group-title">{t.experience.engineeringTitle}</h3>
    <div class="timeline">
      {experienceEngineeringMeta.map((e, i) => (
        <div class="timeline-item">
          <h3>{e.role} · <span style="color:var(--accent)">{e.org}</span></h3>
          <p class="timeline-meta">{t.experience.engineering[i].period}</p>
          <p>{t.experience.engineering[i].summary}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Education -->
<section id="education">
  <div class="container">
    <p class="eyebrow">{t.education.eyebrow}</p>
    <h2 class="section-title">{t.education.title}</h2>
    <div class="timeline">
      {educationMeta.map((e, i) => (
        <div class="timeline-item">
          <h3>{t.education.items[i].degree} · <span style="color:var(--accent)">{e.org}</span></h3>
          <p class="timeline-meta">{t.education.items[i].period}</p>
          <p>{t.education.items[i].summary}</p>
          {e.thesisLink && (
            <p style="margin:0.5rem 0 0">
              <a href={e.thesisLink} target="_blank" rel="noopener">{t.education.items[i].thesisLabel}</a>
            </p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Certifications -->
<section id="certifications">
  <div class="container">
    <p class="eyebrow">{t.certifications.eyebrow}</p>
    <h2 class="section-title">{t.certifications.title}</h2>
    <p class="section-lead">{t.certifications.lead}</p>
    <div class="cert-group">
      <h3>{t.certifications.associateTitle}</h3>
      <ul class="skill-list">
        {certificationsAssociate.map((c) => <li>{c}</li>)}
      </ul>
    </div>
    <div class="cert-group">
      <h3>{t.certifications.fundamentalsTitle}</h3>
      <ul class="skill-list">
        {certificationsFundamentals.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </div>
</section>

<!-- Skills -->
<section id="skills">
  <div class="container">
    <p class="eyebrow">{t.skills.eyebrow}</p>
    <h2 class="section-title">{t.skills.title}</h2>
    <p class="section-lead">{t.skills.lead}</p>
    <div class="toolbox">
      <h3 class="toolbox-title">{t.skills.toolboxTitle}</h3>
      <ul class="toolbox-list">
        {toolbox.map((tool) => (
          <li class="toolbox-item">
            <span
              class="tool-icon"
              role="img"
              aria-label={tool.name}
              title={tool.name}
              style={`--icon: url(${base}icons/${tool.icon}.svg)`}
            ></span>
            <span class="tool-name">{tool.name}</span>
          </li>
        ))}
      </ul>
    </div>
    {skillGroupItems.map((items, i) => (
      <div class="skill-group">
        <h3>{t.skills.groupNames[i]}</h3>
        <ul class="skill-list">
          {items.map((s) => <li>{s}</li>)}
        </ul>
      </div>
    ))}
  </div>
</section>

<!-- Community & Inclusion -->
<section id="community">
  <div class="container">
    <p class="eyebrow">{t.community.eyebrow}</p>
    <h2 class="section-title" set:html={t.community.title}></h2>
    <p class="section-lead">{t.community.lead}</p>
    <div class="grid grid-3">
      {communityMeta.map((c, i) => (
        <article class="card">
          <div class="interest-icon" aria-hidden="true">{c.icon}</div>
          <h3>{t.community.items[i].title}</h3>
          <p style="margin:0" set:html={t.community.items[i].description}></p>
          {t.community.items[i].bullets && (
            <ul style="margin:0.75rem 0 0; padding-left:1.1rem">
              {t.community.items[i].bullets!.map((b) => <li set:html={b}></li>)}
            </ul>
          )}
          {t.community.items[i].note && <p style="margin:0.75rem 0 0">{t.community.items[i].note}</p>}
          {c.links && (
            <p style="margin:0.75rem 0 0" class="community-links">
              {c.links.map((url, li) => (
                <a href={url} target="_blank" rel="noopener">{t.community.items[i].linkLabels?.[li]} →</a>
              ))}
            </p>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Blog preview -->
{articles.length > 0 && (
  <section id="blog-preview">
    <div class="container">
      <p class="eyebrow">{t.blog.eyebrow}</p>
      <h2 class="section-title">{t.blog.title}</h2>
      <p class="section-lead">{t.blog.lead}</p>
      <p class="muted" style="margin:-0.5rem 0 1.5rem; max-width:60ch">{t.blog.note}</p>
      <ul class="post-list">
        {articles.slice(0, 3).map((a) => (
          <li class="post-item card">
            <span class="post-source">{a.source}</span>
            <h3><a href={a.url} target="_blank" rel="noopener">{a.title}</a></h3>
            <p style="margin:0">{a.description}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}

<!-- Resources -->
<section id="resources">
  <div class="container">
    <p class="eyebrow">{t.resources.eyebrow}</p>
    <h2 class="section-title">{t.resources.title}</h2>
    <p class="section-lead">{t.resources.intro}</p>
    <div class="grid grid-2">
      {resourceGroupsMeta.map((g, i) => (
        <article class="card">
          <div class="interest-icon" aria-hidden="true">{g.icon}</div>
          <h3>{t.resources.groupNames[i]}</h3>
          {t.resources.notes[i] && <p style="margin:0 0 0.5rem" class="muted">{t.resources.notes[i]}</p>}
          {g.links.length > 0 ? (
            <ul class="resource-list">
              {g.links.map((l) => (
                <li>
                  <a href={l.url} target="_blank" rel="noopener">{l.label} →</a>
                </li>
              ))}
            </ul>
          ) : (
            <p style="margin:0" class="muted">{t.resources.linksComingSoon}</p>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Interests -->
<section id="interests">
  <div class="container">
    <p class="eyebrow">{t.interests.eyebrow}</p>
    <h2 class="section-title">{t.interests.title}</h2>
    <p class="section-lead">{t.interests.lead}</p>
    <div class="grid grid-3">
      {interestIcons.map((icon, i) => (
        <article class="card">
          <div class="interest-icon" aria-hidden="true">{icon}</div>
          <h3>{t.interests.items[i].title}</h3>
          <p style="margin:0">{t.interests.items[i].description}</p>
          {t.interests.items[i].bullets && (
            <ul class="interest-bullets">
              {t.interests.items[i].bullets!.map((b) => <li>{b}</li>)}
            </ul>
          )}
          {t.interests.items[i].note && <p style="margin:0">{t.interests.items[i].note}</p>}
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact" class="contact">
  <div class="container">
    <p class="eyebrow">{t.contact.eyebrow}</p>
    <h2 class="section-title">{t.contact.title}</h2>
    <p class="section-lead" style="margin-inline:auto">{t.contact.lead}</p>
    <div class="contact-links">
      <a class="btn btn-primary" href={`mailto:${profile.email}`}>{t.contact.emailMe}</a>
      <button class="btn btn-ghost copy-email" data-email={profile.email} data-copied={t.contact.copied} type="button">{t.contact.copyEmail}</button>
      <a class="btn btn-ghost" href={profile.linkedin} rel="noopener">LinkedIn</a>
      <a class="btn btn-ghost" href={profile.github} rel="noopener">GitHub</a>
    </div>
  </div>
</section>

<script is:inline>
  // Copy-email button with brief, localized "Copied!" feedback
  (function () {
    document.addEventListener('click', async (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;
      const btn = target.closest('.copy-email');
      if (!btn) return;
      const email = btn.getAttribute('data-email');
      if (!email) return;
      const copiedLabel = btn.getAttribute('data-copied') || 'Copied!';
      try {
        await navigator.clipboard.writeText(email);
        const original = btn.textContent;
        btn.textContent = copiedLabel;
        setTimeout(() => { btn.textContent = original; }, 1800);
      } catch {
        window.location.href = `mailto:${email}`;
      }
    });
  })();
</script>

<script is:inline>
  // Animate the hero “by the numbers” counters from 0 to their target.
  (function () {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const nums = document.querySelectorAll('.hero-stat-num[data-count]');
    nums.forEach((el) => {
      const raw = el.getAttribute('data-count') || '';
      const target = parseFloat(raw);
      if (!Number.isFinite(target) || target <= 0 || reduce) return;
      const decimals = raw.includes('.') ? 1 : 0;
      el.textContent = (0).toFixed(decimals);
      const duration = 1100;
      const start = performance.now();
      const step = (now) => {
        const p = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = (target * eased).toFixed(decimals);
        if (p < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    });
  })();
</script>
