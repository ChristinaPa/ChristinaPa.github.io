---
import BaseLayout from '../layouts/BaseLayout.astro';
import { articles } from '../data/articles';

const base = import.meta.env.BASE_URL;

// --- Edit your content here -------------------------------------------------
const profile = {
  name: 'Christina Pardali',
  role: 'Partner Solution Architect',
  tagline:
    'Partner Solution Architect at Microsoft EMEA, based in Munich. I work with Microsoft\u2019s partner ecosystem\u2014companies that build, integrate, and deliver solutions on top of Microsoft technologies\u2014to help them design and deploy reliable, secure, and cost-efficient AI applications in the cloud, and drive GitHub adoption across the ecosystem.',
  email: 'xristinapar8@gmail.com',
  phone: '+491751293078',
  linkedin: 'https://www.linkedin.com/in/christine-pardali/',
  github: 'https://github.com/ChristinaPa',
  // Replace with your public Credly profile URL when you have it.
  credly: 'https://www.credly.com/',
  location: 'Munich, Germany',
  welcome:
    'Welcome to my little corner of the internet! I\u2019m a Greek who fell in love with Munich, a Partner Solution Architect at Microsoft by day, and a mountain-chaser and lifelong learner the rest of the time. Grab a coffee, scroll around, and get to know me a bit.',
};

const topics = [
  {
    icon: '🤖',
    title: 'AI applications in the cloud',
    description:
      'Helping partners design and deploy AI applications that are reliable, secure, and production-ready — from first prototype to scale, with a focus on Microsoft Foundry.',
    tags: ['Microsoft Foundry', 'Azure AI', 'GenAI'],
  },
  {
    icon: '🐙',
    title: 'GitHub adoption',
    description:
      'Driving GitHub adoption across the partner ecosystem — modern developer workflows, automation, and GitHub Copilot. And yes, this website was built with GitHub Copilot.',
    tags: ['GitHub', 'Copilot', 'DevOps'],
  },
];

const whatIDo = [
  'Delivering technical trainings and hands-on workshops to upskill partner teams',
  'Running architecture reviews and design sessions to validate solutions before they scale',
  'Building proofs of concept that de-risk new ideas and prove value quickly',
  'Collaborating closely with account teams to align technical strategy with business goals',
  'Guiding partners on reliable, secure, and cost-efficient cloud and AI solutions',
  'Driving GitHub and developer-productivity adoption across the partner ecosystem',
];

const experienceMicrosoft = [
  {
    role: 'Partner Solution Architect — EMEA',
    org: 'Microsoft',
    period: 'Feb 2026 – Present · Munich',
    summary:
      'Work with EMEA partners on AI applications and GitHub adoption, providing technical guidance on building reliable, performant, secure, and cost-efficient cloud solutions and shaping their cloud services offerings. Communications Lead of the Mosaic Inclusion Network in Germany, championing multicultural inclusion and representation.',
  },
  {
    role: 'Data Analytics Cloud Solution Architect — EMEA',
    org: 'Microsoft',
    period: 'Sep 2022 – Feb 2026 · Munich',
    summary:
      'Specialized in Microsoft Fabric, Azure Data Factory, Azure Synapse Analytics, Azure Databricks, and Power BI. Ran proof of concepts and architecture reviews for enterprise customers, delivered technical workshops, drove feature requests with Product Engineering, and coordinated AI and lakehouse migration projects end to end. Delivered Microsoft Fabric sessions at the Microsoft Executive Center EMEA to 50+ senior decision makers.',
  },
  {
    role: 'Sales Executive Intern — Business Applications',
    org: 'Microsoft',
    period: 'Oct 2021 – Mar 2022 · Munich',
    summary:
      'Ran market research and a Dynamics 365 Remote Assist lead-generation campaign for Automotive and Manufacturing accounts using LinkedIn Sales Navigator and Dynamics 365 Sales, built outreach templates, analyzed campaign results, and supported presales demos.',
  },
  {
    role: 'Microsoft Learn Student Ambassador',
    org: 'Microsoft',
    period: 'Jan 2020 – Mar 2022 · Thessaloniki',
    summary:
      'Authored a Microsoft Learn path on Azure Health Bot and spoke at virtual events on Azure Machine Learning, Power Platform, Cloud Security, and Health Bot — including the Global AI Student Conference 2021 — while building local tech communities.',
  },
];

const experienceEngineering = [
  {
    role: 'Junior Radio Frequency Engineer',
    org: 'Further Enterprise Solutions (FES)',
    period: 'Jun 2021 – Sep 2021 · Thessaloniki',
    summary:
      'Supported radio frequency engineering, including E911 call testing for small cells and creating KPI reports for network efficiency.',
  },
  {
    role: 'Network Infrastructure Intern',
    org: 'Aristotle University IT Center',
    period: 'Jan 2020 – Jun 2020 · Thessaloniki',
    summary:
      'Gained hands-on experience in network management, traffic accounting, wireless networks, routing, and switching using LibreNMS, Icinga, SecureCRT, and Cisco Prime Infrastructure.',
  },
];

const education = [
  {
    degree: 'M.Eng. Electrical & Computer Engineering — Telecommunications',
    org: 'Aristotle University of Thessaloniki (AUTH)',
    period: '2016 – 2022',
    summary: 'Telecommunications Engineering. Thesis: Interference in novel leadless pacemaker implants.',
    thesisLink: 'https://ikee.lib.auth.gr/record/338089/?ln=el',
  },
];

const certificationsAssociate = [
  'Microsoft Fabric Analytics Engineer Associate',
  'Microsoft Certified: Azure Data Engineer Associate',
  'Microsoft Certified: Azure AI Engineer Associate',
];

const certificationsFundamentals = [
  'Microsoft Certified: Azure Fundamentals',
  'Microsoft Certified: Azure AI Fundamentals',
  'Microsoft Certified: Azure Data Fundamentals',
  'Microsoft Certified: Dynamics 365 Fundamentals (CRM)',
  'Databricks Lakehouse Fundamentals',
  'Databricks Generative AI Fundamentals',
  'GitHub Foundations',
  'GitHub Copilot',
  'GitHub Actions',
];

const skillGroups = [
  {
    name: 'Data & Analytics',
    items: ['Microsoft Fabric', 'Azure Synapse Analytics', 'Azure Data Factory', 'Azure Databricks', 'Power BI', 'Spark'],
  },
  {
    name: 'Programming',
    items: ['Python', 'SQL'],
  },
  {
    name: 'AI',
    items: ['Azure AI', 'Generative AI', 'Azure Machine Learning', 'Azure Health Bot'],
  },
  {
    name: 'Cloud & Architecture',
    items: ['Azure', 'Solution Architecture', 'Lakehouse', 'Proof of Concepts', 'Architecture Reviews'],
  },
];

const interests = [
  {
    icon: '🥾',
    title: 'Hiking adventures',
    description: 'Hiking is my favourite way to switch off. Two trails I\'ll never forget:',
    bullets: [
      'Trekking to Everest Base Camp in Nepal 🇳🇵',
      'Standing on top of the Zugspitze, Germany\'s highest peak 🇩🇪',
    ],
    note: 'Closer to home, most weekends you\'ll find me somewhere in the Bavarian Alps.',
  },
  {
    icon: '✈️',
    title: 'Travel & exploring',
    description:
      'I love exploring cultures outside of Europe and usually combine my trips with a good hike. And yes — at 28, I still text my mum the moment I land somewhere new.',
  },
  {
    icon: '🏃‍♀️',
    title: 'Running',
    description:
      'Mostly I just try to run 10 km without dying.',
  },
  {
    icon: '🌱',
    title: 'Mentoring',
    description:
      'I love mentoring students and early-in-career professionals — helping people break into tech, navigate their first cloud or AI roles, and grow the confidence to back themselves.',
  },
];

const community = [
  {
    icon: '🌍',
    title: 'Mosaic Inclusion Network',
    description:
      'Communications Lead of the Mosaic Inclusion Network at Microsoft Germany, championing multicultural inclusion and representation across our community at Microsoft.',
  },
  {
    icon: '💻',
    title: 'ReDI School volunteering',
    description:
      'Volunteering with ReDI School of Digital Integration: I taught a semester of AI Fundamentals to newcomers as part of a group of teachers, and returned twice as a train-the-trainer mentor, coaching teachers on how to use AI in their own teaching.',
    link: 'https://www.redi-school.org/',
    linkLabel: 'Visit ReDI School',
  },
  {
    icon: '🎓',
    title: 'Student leadership & volunteering',
    description:
      'From AIESEC and the Student Conference of Electrical and Computer Engineering (ECESCON) to my time as a Microsoft Learn Student Ambassador, I have always invested in mentoring others and growing diverse tech communities.',
    links: [
      { url: 'https://aiesec.org/', label: 'AIESEC' },
      { url: 'https://mvp.microsoft.com/studentambassadors', label: 'Microsoft Learn Student Ambassadors' },
    ],
  },
];

const funFacts = [
  '🇬🇷 Greek at heart',
  '🏔️ Munich-based',
  '🥾 Hiked to Everest Base Camp',
  '☕ Coffee-powered',
  '🗣️ Speaks Greek, English & German',
  '🤖 Built this site with Copilot',
];
// ---------------------------------------------------------------------------
---

<BaseLayout title={`${profile.name} — ${profile.role}`} description={profile.tagline}>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="avatar-wrap">
        <img
          class="avatar"
          src={`${base}profile.jpg`}
          alt={profile.name}
          width="150"
          height="150"
          loading="eager"
          onerror="this.style.display='none'"
        />
        <span class="avatar-initials" aria-hidden="true">CP</span>
      </div>
      <p class="eyebrow">{profile.role}</p>
      <h1>Hi, I'm <span class="gradient">{profile.name}</span></h1>
      <p class="tagline">{profile.welcome}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="#contact">Get in touch</a>
        <a class="btn btn-ghost" href="#focus">What I do</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about">
    <div class="container">
      <p class="eyebrow">About</p>
      <h2 class="section-title">A bit about me</h2>
      <div class="about-grid">
        <div>
          <p>
            <span class="about-lead">👋 Hi!</span> I'm a Partner Solution Architect on Microsoft's
            EMEA team, based in Munich. Originally from Thessaloniki, Greece, I moved to Munich when
            I was 23 and have called it home ever since. I work with partners to build reliable,
            performant, secure, and cost-efficient AI applications in the cloud, help them shape
            their cloud services offerings, and drive GitHub adoption across the ecosystem.
          </p>
          <p>
            <span class="about-lead">📊 Before that</span> I spent three and a half years as a Data
            Analytics Cloud Solution Architect, specializing in Microsoft Fabric, Azure Databricks,
            Synapse, Data Factory, and Power BI. I love delivering technical workshops and sharing
            what I learn.
          </p>
          <p>
            <span class="about-lead">🎤 Beyond the day job</span> I deliver executive briefings —
            sessions where I meet with customer leadership teams to cut through the noise on AI and
            translate the technology into clear business value. Alongside this, I serve as
            Communications Lead of the Mosaic Inclusion Network in Germany, championing multicultural
            inclusion and representation across our community at Microsoft.
          </p>
          <ul class="fun-facts" aria-label="Quick facts about me">
            {funFacts.map((f) => <li>{f}</li>)}
          </ul>
        </div>
        <div class="about-facts">
          <div class="fact"><span>💼 Role</span><span>{profile.role}</span></div>
          <div class="fact"><span>📍 Location</span><span>{profile.location}</span></div>
          <div class="fact"><span>🎯 Focus</span><span>AI Apps · Azure · GitHub</span></div>
          <div class="fact"><span>🗣️ Languages</span><span>Greek · English · German</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Focus areas with partners -->
  <section id="focus">
    <div class="container">
      <p class="eyebrow">What I do</p>
      <h2 class="section-title">Focus areas</h2>
      <p class="section-lead">Areas where I help Microsoft partners design, build, and ship.</p>
      <div class="grid grid-3">
        {topics.map((t) => (
          <article class="card">
            <div class="interest-icon" aria-hidden="true">{t.icon}</div>
            <h3>{t.title}</h3>
            <p>{t.description}</p>
            <div class="tag-row">
              {t.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </article>
        ))}
      </div>

      <div class="what-i-do">
        <h3 class="experience-group-title">In a typical week</h3>
        <p class="section-lead">
          My work has a particular focus on the German market 🇩🇪.
        </p>
        <ul class="what-i-do-list">
          {whatIDo.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience">
    <div class="container">
      <p class="eyebrow">Career</p>
      <h2 class="section-title">Work experience</h2>
      <p class="section-lead">Where I've worked and what I focused on.</p>

      <h3 class="experience-group-title">My Microsoft journey</h3>
      <div class="timeline">
        {experienceMicrosoft.map((e) => (
          <div class="timeline-item">
            <h3>{e.role}</h3>
            <p class="timeline-meta">{e.period}</p>
            <p>{e.summary}</p>
          </div>
        ))}
      </div>

      <h3 class="experience-group-title">When I thought I wanted to work as an engineer</h3>
      <div class="timeline">
        {experienceEngineering.map((e) => (
          <div class="timeline-item">
            <h3>{e.role} · <span style="color:var(--accent)">{e.org}</span></h3>
            <p class="timeline-meta">{e.period}</p>
            <p>{e.summary}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Education -->
  <section id="education">
    <div class="container">
      <p class="eyebrow">Education</p>
      <h2 class="section-title">Education</h2>
      <div class="timeline">
        {education.map((e) => (
          <div class="timeline-item">
            <h3>{e.degree} · <span style="color:var(--accent)">{e.org}</span></h3>
            <p class="timeline-meta">{e.period}</p>
            <p>{e.summary}</p>
            {e.thesisLink && (
              <p style="margin:0.5rem 0 0">
                <a href={e.thesisLink} target="_blank" rel="noopener">Read my thesis →</a>
              </p>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section id="certifications">
    <div class="container">
      <p class="eyebrow">Credentials</p>
      <h2 class="section-title">Certifications</h2>
      <p class="section-lead">
        Microsoft and Databricks certifications.
      </p>
      <div class="cert-group">
        <h3>Associate level</h3>
        <ul class="skill-list">
          {certificationsAssociate.map((c) => <li>{c}</li>)}
        </ul>
      </div>
      <div class="cert-group">
        <h3>Fundamentals</h3>
        <ul class="skill-list">
          {certificationsFundamentals.map((c) => <li>{c}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills">
    <div class="container">
      <p class="eyebrow">Toolbox</p>
      <h2 class="section-title">Skills</h2>
      <p class="section-lead">Technologies and practices I work with regularly.</p>
      {skillGroups.map((g) => (
        <div class="skill-group">
          <h3>{g.name}</h3>
          <ul class="skill-list">
            {g.items.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Community & Inclusion -->
  <section id="community">
    <div class="container">
      <p class="eyebrow">What I care about</p>
      <h2 class="section-title">Community &amp; inclusion</h2>
      <p class="section-lead">
        Beyond architecture, I'm passionate about multicultural communities and inclusion — bringing
        people together and making sure everyone has a seat at the table.
      </p>
      <div class="grid grid-3">
        {community.map((c) => (
          <article class="card">
            <div class="interest-icon" aria-hidden="true">{c.icon}</div>
            <h3>{c.title}</h3>
            <p style="margin:0">{c.description}</p>
            {c.link && (
              <p style="margin:0.75rem 0 0">
                <a href={c.link} target="_blank" rel="noopener">{c.linkLabel} →</a>
              </p>
            )}
            {c.links && (
              <p style="margin:0.75rem 0 0" class="community-links">
                {c.links.map((l) => (
                  <a href={l.url} target="_blank" rel="noopener">{l.label} →</a>
                ))}
              </p>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog preview -->
  {articles.length > 0 && (
    <section id="blog-preview">
      <div class="container">
        <p class="eyebrow">Writing</p>
        <h2 class="section-title">From the blog</h2>
        <p class="section-lead">Articles I've published on cloud, AI, and architecture.</p>
        <ul class="post-list">
          {articles.slice(0, 3).map((a) => (
            <li class="post-item card">
              <span class="post-source">{a.source}</span>
              <h3><a href={a.url} target="_blank" rel="noopener">{a.title}</a></h3>
              <p style="margin:0">{a.description}</p>
            </li>
          ))}
        </ul>
        <p style="margin-top:1.5rem">
          <a class="btn btn-ghost" href={`${base}blog`}>All articles →</a>
        </p>
      </div>
    </section>
  )}

  <!-- Interests -->
  <section id="interests">
    <div class="container">
      <p class="eyebrow">Beyond work</p>
      <h2 class="section-title">Personal interests</h2>
      <p class="section-lead">
        When I'm not designing data and AI solutions, I'm usually outdoors — most often on a mountain trail.
      </p>
      <div class="grid grid-3">
        {interests.map((i) => (
          <article class="card">
            <div class="interest-icon" aria-hidden="true">{i.icon}</div>
            <h3>{i.title}</h3>
            <p style="margin:0">{i.description}</p>
            {i.bullets && (
              <ul class="interest-bullets">
                {i.bullets.map((b) => <li>{b}</li>)}
              </ul>
            )}
            {i.note && <p style="margin:0">{i.note}</p>}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="contact">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h2 class="section-title">Let's connect</h2>
      <p class="section-lead" style="margin-inline:auto">
        Interested in collaborating, or just want to say hi? I'd love to hear from you.
      </p>
      <div class="contact-links">
        <a class="btn btn-primary" href={`mailto:${profile.email}`}>Email me</a>
        <a class="btn btn-ghost" href={profile.linkedin} rel="noopener">LinkedIn</a>
        <a class="btn btn-ghost" href={profile.github} rel="noopener">GitHub</a>
      </div>
    </div>
  </section>
</BaseLayout>
