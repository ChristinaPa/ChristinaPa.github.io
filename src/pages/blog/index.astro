---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { articles } from '../../data/articles';
---

<BaseLayout title="Blog — Christina Pardali" description="Articles and writing by Christina Pardali.">
  <section>
    <div class="container">
      <p class="eyebrow">Writing</p>
      <h1 class="section-title">Blog</h1>
      <p class="section-lead">Articles I've published on cloud, AI, and architecture.</p>
      <ul class="post-list">
        {articles.map((a) => (
          <li class="post-item card">
            <span class="post-source">{a.source}</span>
            <h3><a href={a.url} target="_blank" rel="noopener">{a.title}</a></h3>
            <p style="margin:0">{a.description}</p>
            <p style="margin:0.75rem 0 0">
              <a href={a.url} target="_blank" rel="noopener">Read on {a.source} →</a>
            </p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

