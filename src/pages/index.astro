---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

// --- Edit your content here -------------------------------------------------
const profile = {
  name: 'Christina Pardali',
  // Official CV title. If you currently go by "Partner Solution Architect",
  // just change this line.
  role: 'AI & Analytics Cloud Solution Architect',
  tagline:
    'I help EMEA enterprise customers design and deliver data and AI solutions on Azure and Microsoft Fabric — from proof of concept to production lakehouse and AI migrations.',
  email: 'xristinapar8@gmail.com',
  phone: '+491751293078',
  linkedin: 'https://www.linkedin.com/in/christine-pardali/',
  github: 'https://github.com/ChristinaPa',
  // Replace with your public Credly profile URL when you have it.
  credly: 'https://www.credly.com/',
  location: 'Munich, Germany',
};

const projects = [
  {
    title: 'AI & Lakehouse Migration Projects',
    description:
      'Coordinate AI and lakehouse migration projects for EMEA enterprise customers — owning architecture design, managing stakeholders, and aligning delivery with business objectives and revenue targets.',
    tags: ['Microsoft Fabric', 'Lakehouse', 'Azure AI'],
    link: profile.linkedin,
  },
  {
    title: 'Azure Health Bot Learning Path',
    description:
      'Authored a Microsoft Learn path teaching developers how to build healthcare bots with the Azure Health Bot service.',
    tags: ['Azure Health Bot', 'Microsoft Learn', 'AI'],
    link: 'https://docs.microsoft.com/en-us/learn/paths/create-bots-azure-health-bot/',
  },
  {
    title: 'Technical Workshops & Enablement',
    description:
      'Designed and delivered technical workshops and 7 virtual events on Azure ML Studio, Power Platform, Cloud Security, and Health Bot for enterprise customers and the community.',
    tags: ['Workshops', 'Enablement', 'Azure'],
    link: profile.linkedin,
  },
];

const experience = [
  {
    role: 'AI & Analytics Cloud Solution Architect',
    org: 'Microsoft EMEA — Technical Strategy Team',
    period: '09/2022 – Present',
    summary:
      'Specialize in Microsoft Fabric, Azure Data Factory, Azure Synapse Analytics, Power BI, Azure Databricks, and Azure AI. Run proof of concepts and architecture reviews for EMEA enterprise customers, deliver technical workshops, write guidance for the internal community, and drive feature requests with Product Engineering. Coordinate AI and lakehouse migration projects end to end — owning architecture, timelines, and stakeholder communication.',
  },
  {
    role: 'Business Applications Sales Executive Intern',
    org: 'Microsoft Germany',
    period: '10/2021 – 03/2022',
    summary:
      'Ran remote assist sales campaigns using LinkedIn Sales Navigator and Dynamics 365 Sales for Automotive, Manufacturing, and Retail accounts, mapping customer vision to product value to move prospects to close.',
  },
  {
    role: 'Microsoft Learn Student Ambassador',
    org: 'Microsoft',
    period: '01/2020 – 04/2022',
    summary:
      'Conducted 7 technical virtual events on Azure Machine Learning Studio, Microsoft Power Platform, Cloud Security, and Health Bot, and developed a Microsoft Learn path for the Azure Health Bot service.',
  },
  {
    role: 'Junior Radio Frequency Engineer',
    org: 'Further Enterprise Solutions',
    period: '06/2021 – 09/2021',
    summary:
      'Prepared E911 call testing for small cells in the Texas market and created KPI reports for network efficiency.',
  },
  {
    role: 'Network Infrastructure Intern',
    org: 'Aristotle University IT Center',
    period: '01/2020 – 06/2020',
    summary:
      'Worked on network management and monitoring, traffic accounting, wireless networks, routing, and switching using LibreNMS, Icinga, SecureCRT, and Cisco Prime Infrastructure.',
  },
];

const education = [
  {
    degree: 'Integrated Master — Electrical & Computer Engineering',
    org: 'Aristotle University of Thessaloniki — Telecommunications Sector',
    period: '10/2016 – 04/2022',
    summary: 'Thesis: Interference in novel leadless pacemaker implants.',
  },
];

const certifications = [
  'Microsoft Fabric Analytics Engineer Associate',
  'Microsoft Certified: Azure Data Engineer Associate',
  'Microsoft Certified: Azure AI Engineer Associate',
  'Microsoft Certified: Azure Data Fundamentals',
  'Microsoft Certified: Azure Fundamentals',
  'Microsoft Certified: Azure AI Fundamentals',
  'Databricks Lakehouse Fundamentals',
  'Databricks Generative AI Fundamentals',
];

const skillGroups = [
  {
    name: 'Data & Analytics',
    items: ['Microsoft Fabric', 'Azure Synapse Analytics', 'Azure Data Factory', 'Azure Databricks', 'Power BI', 'Spark'],
  },
  {
    name: 'Programming',
    items: ['Python', 'SQL'],
  },
  {
    name: 'AI',
    items: ['Azure AI', 'Generative AI', 'Azure Machine Learning', 'Azure Health Bot'],
  },
  {
    name: 'Cloud & Architecture',
    items: ['Azure', 'Solution Architecture', 'Lakehouse', 'Proof of Concepts', 'Architecture Reviews'],
  },
];
// ---------------------------------------------------------------------------

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title={`${profile.name} — ${profile.role}`} description={profile.tagline}>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">{profile.role}</p>
      <h1>Hi, I'm <span class="gradient">{profile.name}</span></h1>
      <p class="tagline">{profile.tagline}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="#contact">Get in touch</a>
        <a class="btn btn-ghost" href="#projects">View work</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about">
    <div class="container">
      <p class="eyebrow">About</p>
      <h2 class="section-title">A bit about me</h2>
      <div class="about-grid">
        <div>
          <p>
            I'm an AI &amp; Analytics Cloud Solution Architect on Microsoft's EMEA Technical Strategy
            team, based in Munich. I work with enterprise customers to design data and AI solutions on
            Azure and Microsoft Fabric — running proof of concepts, architecture reviews, and
            end-to-end lakehouse and AI migrations.
          </p>
          <p>
            I love turning complex data problems into clear, buildable architectures, delivering
            hands-on technical workshops, and sharing what I learn with the community. My background
            spans data engineering, AI, and telecommunications.
          </p>
        </div>
        <div class="about-facts">
          <div class="fact"><span>Role</span><span>{profile.role}</span></div>
          <div class="fact"><span>Location</span><span>{profile.location}</span></div>
          <div class="fact"><span>Focus</span><span>Data · AI · Analytics</span></div>
          <div class="fact"><span>Languages</span><span>EN · EL · DE</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects">
    <div class="container">
      <p class="eyebrow">Portfolio</p>
      <h2 class="section-title">Selected projects</h2>
      <p class="section-lead">A few things I've designed, built, or contributed to.</p>
      <div class="grid grid-3">
        {projects.map((p) => (
          <article class="card">
            <h3>{p.title}</h3>
            <p>{p.description}</p>
            <div class="tag-row">
              {p.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            {p.link && (
              <p style="margin-top:1rem;margin-bottom:0">
                <a href={p.link} rel="noopener">View →</a>
              </p>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience">
    <div class="container">
      <p class="eyebrow">Career</p>
      <h2 class="section-title">Experience</h2>
      <p class="section-lead">Where I've worked and what I focused on.</p>
      <div class="timeline">
        {experience.map((e) => (
          <div class="timeline-item">
            <h3>{e.role} · <span style="color:var(--accent)">{e.org}</span></h3>
            <p class="timeline-meta">{e.period}</p>
            <p>{e.summary}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Education -->
  <section id="education">
    <div class="container">
      <p class="eyebrow">Education</p>
      <h2 class="section-title">Education</h2>
      <div class="timeline">
        {education.map((e) => (
          <div class="timeline-item">
            <h3>{e.degree} · <span style="color:var(--accent)">{e.org}</span></h3>
            <p class="timeline-meta">{e.period}</p>
            <p>{e.summary}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section id="certifications">
    <div class="container">
      <p class="eyebrow">Credentials</p>
      <h2 class="section-title">Certifications</h2>
      <p class="section-lead">
        Microsoft and Databricks certifications.{' '}
        <a href={profile.credly} rel="noopener">View on Credly →</a>
      </p>
      <ul class="skill-list">
        {certifications.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills">
    <div class="container">
      <p class="eyebrow">Toolbox</p>
      <h2 class="section-title">Skills</h2>
      <p class="section-lead">Technologies and practices I work with regularly.</p>
      {skillGroups.map((g) => (
        <div class="skill-group">
          <h3>{g.name}</h3>
          <ul class="skill-list">
            {g.items.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Blog preview -->
  {posts.length > 0 && (
    <section id="blog-preview">
      <div class="container">
        <p class="eyebrow">Writing</p>
        <h2 class="section-title">From the blog</h2>
        <p class="section-lead">Thoughts on architecture, cloud, and building things.</p>
        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-item card">
              <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
              <h3><a href={`${base}blog/${post.id}`}>{post.data.title}</a></h3>
              <p style="margin:0">{post.data.description}</p>
            </li>
          ))}
        </ul>
        <p style="margin-top:1.5rem">
          <a class="btn btn-ghost" href={`${base}blog`}>All posts →</a>
        </p>
      </div>
    </section>
  )}

  <!-- Contact -->
  <section id="contact" class="contact">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h2 class="section-title">Let's connect</h2>
      <p class="section-lead" style="margin-inline:auto">
        Interested in collaborating, or just want to say hi? I'd love to hear from you.
      </p>
      <div class="contact-links">
        <a class="btn btn-primary" href={`mailto:${profile.email}`}>Email me</a>
        <a class="btn btn-ghost" href={profile.linkedin} rel="noopener">LinkedIn</a>
        <a class="btn btn-ghost" href={profile.github} rel="noopener">GitHub</a>
      </div>
    </div>
  </section>
</BaseLayout>
